{
  "name": "ember",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node --import tsx scripts/extract-strings.ts && node scripts/generate-service-worker.mjs",
    "budget": "node scripts/check-build-budget.mjs",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "verify": "npm run check && npm run test && npm run proofread && npm run build && npm run budget && npm run offline",
    "proofread": "node --import tsx scripts/proofread-content.ts",
    "offline": "node scripts/check-offline-build.mjs",
    "preview": "vite preview",
    "sim": "tsx balance/simulate.ts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
